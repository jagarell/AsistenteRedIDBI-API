# Variables de entorno del servicio FastAPI de IDBI.
# Copia a .env (ignorado por git) y completa con valores reales del vault.

# --- Base de datos (para futura persistencia) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/idbi_db

# --- Seguridad / JWT (para futura autenticación en este servicio) ---
SECRET_KEY=colocar_clave_secreta_de_al_menos_32_bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Motor de generacion de propuesta del chat ---
# 'builtin' (reglas, por defecto), 'flowise' o 'openai'.
CHAT_PROPOSAL_ENGINE=builtin
CHAT_HTTP_TIMEOUT=20

# --- Seam Flowise (solo si CHAT_PROPOSAL_ENGINE=flowise) ---
FLOWISE_URL=
FLOWISE_API_KEY=
FLOWISE_CHATFLOW_ID=

# --- Seam OpenAI (solo si CHAT_PROPOSAL_ENGINE=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
